{
  "AppName": "fleet-apigateway-service",
  "Environment": "__Environment__",
  "DynamicRouting": {
    "AllowedServices": [
      "fleet-account-service",
      "fleet-onboarding-service",
      "fleet-company-service"
    ]
  },
  "AllowedHosts": "__AllowedHosts__",
  "ConnectionStrings": {
    "RedisConnection": "__RedisConnection__"
  },
  "CorsPolicy": {
    "AllowedOrigins": "__CorsOrigins__",
    "AllowedMethods": "__CorsMethods__",
    "AllowedHeaders": "__CorsHeaders__"
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "__B2CTenantId__",
    "ClientId": "__GatewayClientId__",
    "ClientSecret": "__GatewayClientSecret__",
    "Scopes": ["api://__ClientId__/.default"]
  },
  "AzureAdB2C": {
    "Instance": "__B2CInstance__",
    "Domain": "__B2CDomain__",
    "ClientId": "__WebApp_ClientId__",
    "SignUpSignInPolicyId": "__B2CSignIn__",
    "ValidAudiences": [
      "__WebApp_ClientId__",
      "__GatewayBrokerClientId__"
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "dynamic-service-route": {
        "ClusterId": "dynamic-cluster",
        "Match": { "Path": "/{service-name}/{**catch-all}"},
        "Transforms": [
          { "PathPattern": "/{**catch-all}" },
          { "RequestHeaderOriginalHost": "true" }
        ],
        "Order": 100
      }
    },
    "Clusters": {
      "dynamic-cluster": {
        "HttpRequest": {
          "ActivityTimeout": "00:00:30"
        },
        "Destinations": {
          "dynamic-destination": { "Address": "http://__Environment__-{service-name}:8080" }
        }
      }
    }
  }
}
