{
  "AppName": "fleet-apigateway-service",
  "Environment": "Sandbox",
  "AllowedHosts": "*",
  "Keycloak": {
    "AuthServerUrl": "https://keycloak:8443",
    "Realm": "sandbox-realm",
    "Resource": "InternalServiceApp",
    "Credentials": {
      "Secret": "internal-service-secret"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "dynamic-service-route": {
        "ClusterId": "dynamic-cluster",
        "Match": { "Path": "/{service-name}/{**catch-all}"},
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ],
        "Order": 100
      }
    },
    "Clusters": {
      "dynamic-cluster": {
        "Destinations": {
          "dynamic-destination": { "Address": "http://{service-name}:8080" }
        }
      }
    }
  }
}


